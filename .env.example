# Database — on Railway set this to a reference: ${{ Postgres.DATABASE_URL }}
DATABASE_URL="postgresql://user:pass@localhost:5432/ijri?schema=public"

# Auth
AUTH_SECRET="generate-a-long-random-string"
NEXT_PUBLIC_SITE_URL="https://ijri.in"

# Object storage (S3-compatible: Railway Bucket OR Cloudflare R2)
# R2: S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com , S3_REGION=auto
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="ijri-pdfs"
PDF_URL_TTL="300"
